        </div>

        <!-- Footer CTA -->
        <div
          style="margin-top:16px;padding:24px;background:#1a1d27;border:1px solid #2d3148;border-radius:12px;text-align:center;"
        >
          <p style="font-size:0.9rem;color:#94a3b8;margin:0 0 16px;">
            Prêt à commencer ? Retourne sur l'application.
          </p>
          <a
            href="/"
            class="btn btn-primary"
            style="display:inline-flex;text-decoration:none;padding:10px 28px;font-size:0.9rem;"
