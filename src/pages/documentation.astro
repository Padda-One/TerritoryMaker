    <meta property="og:image" content="https://territory.paddaone.com/og-preview.png" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Documentation — Territory Maker" />
    <meta name="twitter:description" content="Guide complet pour utiliser Territory Maker : clé API Google Maps, tracé de territoires, export KML." />
    <meta name="twitter:image" content="https://territory.paddaone.com/og-preview.png" />

    <!-- Structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      "name": "Documentation — Territory Maker",
      "description": "Guide complet pour utiliser Territory Maker : obtenir une clé API Google Maps, tracer des territoires géographiques, gérer des polygones et exporter en KML.",
      "url": "https://territory.paddaone.com/documentation",
      "inLanguage": "fr",
      "author": {
        "@type": "Person",
        "name": "Paddaone",
        "url": "https://github.com/Padda-One"
      },
      "isPartOf": {
        "@type": "SoftwareApplication",
        "name": "Territory Maker",
        "url": "https://territory.paddaone.com"
      }
    }
    </script>

    <title>Documentation — Territory Maker</title>
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="icon" type="image/png" href="/favicon-48x48.png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/svg+xml" href="/logo-TerritoryMaker.svg" />

    <!-- Plausible Analytics (auto-hébergé, proxifié via Cloudflare Worker) -->
    <script
      defer
      data-domain="territory.paddaone.com"
      data-api="https://territory.paddaone.com/3wpjej9/event"
      src="https://territory.paddaone.com/3wpjej9/script.outbound-links.js"
    ></script>
  </head>

