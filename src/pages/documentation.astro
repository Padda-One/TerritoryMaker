              <li>
                <a href="#ch5-2" class="sidebar-sub-link"
                  >Copier ou télécharger</a
                >
              </li>
            </ol>
          </li>
          <li>
            <a href="#ch6" class="sidebar-chapter-link">
              <span class="sidebar-num">6</span>
              <span>Personnalisation</span>
            </a>
            <ol class="sidebar-sub-list">
