        "@type": "SoftwareApplication",
        "name": "Territory Maker",
        "url": "https://territory.paddaone.com"
      }
    }
    </script>

    <title>Documentation — Territory Maker</title>
    <link rel="icon" type="image/svg+xml" href="/logo-TerritoryMaker.svg" />

    <!-- Plausible Analytics (auto-hébergé, proxifié via Cloudflare Worker) -->
    <script
      defer
      data-domain="territory.paddaone.com"
      data-api="https://territory.paddaone.com/3wpjej9/event"
      src="https://territory.paddaone.com/3wpjej9/script.outbound-links.js"
      crossorigin="anonymous"
    ></script>
  </head>

