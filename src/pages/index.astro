      </div><!-- /#map-panel -->

      <!-- Sidebar resize handle -->
      <div id="sidebar-resize" aria-hidden="true"></div>
    </aside><!-- /aside -->

    <!-- ═══════════════════════════════════════════════════════════════════════
         MAP AREA
    ══════════════════════════════════════════════════════════════════════════ -->
    <main style="position:relative;flex:1;overflow:hidden;z-index:0;">
      <!-- Segment mode toggle -->
      <div
        style="position:absolute;top:16px;left:50%;transform:translateX(-50%);z-index:1000;"
