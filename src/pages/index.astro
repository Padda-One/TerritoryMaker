          </div>
          <button
            id="btn-simplify-all"
            class="btn btn-secondary"
            style="width:100%;"
            disabled
          >
            ⬡ Simplifier les zones
          </button>
          <button
            id="btn-export-kml"
            class="btn btn-blue"
            style="width:100%;"
            disabled
          >
            🗺 Exporter la carte
          </button>
        </div>

        <!-- KML export panel (collapsible) -->
        <div
          id="kml-panel"
