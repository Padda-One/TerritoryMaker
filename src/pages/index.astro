---
import "../styles/global.css";
---

<!doctype html>
<html lang="fr" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tracez un territoire sur Google Maps en combinant segments routiers et lignes droites, puis exportez en KML." />
    <title>Territory Maker</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body style="display:flex;height:100vh;overflow:hidden;background-color:var(--color-bg);color:var(--color-text);">

    <!-- ═══════════════════════════════════════════════════════════════════════
         SIDEBAR
    ══════════════════════════════════════════════════════════════════════════ -->
    <aside
      style="width:288px;min-width:288px;background:var(--color-surface);border-right:1px solid var(--color-border);display:flex;flex-direction:column;height:100%;"
    >
      <!-- Header -->
      <div style="padding:14px 16px 12px;border-bottom:1px solid var(--color-border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
        <div style="display:flex;align-items:center;gap:8px;">
          <img src="/favicon.svg" width="22" height="22" alt="" />
          <div>
            <h1 style="font-size:0.95rem;font-weight:700;color:var(--color-text);margin:0;line-height:1.2;">Territory Maker</h1>
            <p style="font-size:0.68rem;color:var(--color-text-muted);margin:1px 0 0;">Tracez · Exportez · KML</p>
          </div>
        </div>
        <button id="btn-settings-toggle" class="btn-icon" title="Paramètres">⚙</button>
      </div>

      <!-- ─── SETTINGS PANEL ──────────────────────────────────────────────── -->
      <div id="settings-panel" style="display:flex;flex-direction:column;flex:1;overflow-y:auto;">

        <!-- API Key section -->
        <div class="settings-section">
          <p class="settings-section-title">Clé Google Maps API</p>

          <!-- Key form (shown when no key stored) -->
          <div id="key-form-section" style="display:flex;flex-direction:column;gap:10px;">
            <p style="font-size:0.75rem;color:var(--color-text-muted);margin:0;line-height:1.5;">
              Nécessite l'activation de <strong style="color:var(--color-text);">Maps JavaScript API</strong>
              et <strong style="color:var(--color-text);">Directions API</strong>.
            </p>
            <a href="/api-key" class="guide-link">
              📖 Pas encore de clé ? Guide pas à pas →
            </a>
            <form id="key-form" style="display:flex;flex-direction:column;gap:8px;">
              <input
                id="key-input"
                type="password"
                class="input-dark"
                placeholder="AIza…"
                autocomplete="off"
                spellcheck="false"
                required
              />
              <button type="submit" class="btn btn-primary" style="width:100%;">
                Charger la carte
              </button>
            </form>
          </div>

          <!-- Key status (shown when key is stored) -->
          <div id="key-stored-section" style="display:none;flex-direction:column;gap:10px;">
            <div class="key-status-box">
              <span style="font-size:1.2rem;">🔑</span>
              <div>
                <strong style="font-size:0.82rem;color:var(--color-text);">Clé API enregistrée</strong>
                <p style="margin:3px 0 0;font-size:0.73rem;color:var(--color-text-muted);">
                  Chiffrée localement (AES-GCM 256 bits).
                </p>
              </div>
            </div>
            <button id="btn-forget-key" class="btn btn-danger" style="width:100%;font-size:0.78rem;">
              🗝 Oublier la clé API
            </button>
          </div>

          <!-- Security notices -->
          <div class="notice-box">
            <div style="display:flex;gap:6px;align-items:flex-start;">
              <span style="font-size:1rem;flex-shrink:0;">🔒</span>
              <div>
                <strong style="color:var(--color-text);font-size:0.78rem;">Stockage local chiffré</strong>
                <p style="margin:4px 0 0;font-size:0.73rem;">
                  Ta clé reste sur ton appareil. Elle n'est jamais envoyée à nos serveurs.
                </p>
              </div>
            </div>
          </div>
          <div class="notice-box" style="border-color:rgba(251,191,36,0.25);background:rgba(251,191,36,0.06);">
            <div style="display:flex;gap:6px;align-items:flex-start;">
              <span style="font-size:1rem;flex-shrink:0;">⚠️</span>
              <div>
                <strong style="color:#fbbf24;font-size:0.78rem;">Restreins ta clé API</strong>
                <p style="margin:4px 0 0;font-size:0.73rem;color:var(--color-text-muted);">
                  Limite ta clé à ton domaine dans
                  <a
                    href="https://console.cloud.google.com/apis/credentials"
                    target="_blank"
                    rel="noopener noreferrer"
                    style="color:var(--color-accent-blue);"
                  >Google Cloud Console</a>
                  pour éviter tout usage non autorisé.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Appearance section -->
        <div class="settings-section">
          <p class="settings-section-title">Apparence</p>

          <div>
            <p class="settings-row-label">Thème de l'application</p>
            <div class="theme-picker" id="app-theme-picker">
              <button class="theme-btn" data-value="dark">🌙 Sombre</button>
              <button class="theme-btn" data-value="light">☀️ Clair</button>
              <button class="theme-btn" data-value="system">⚙ Système</button>
            </div>
          </div>

          <div>
            <p class="settings-row-label">Thème de la carte</p>
            <div class="theme-picker" id="map-theme-picker">
              <button class="theme-btn" data-value="dark">Sombre</button>
              <button class="theme-btn" data-value="light">Clair</button>
              <button class="theme-btn" data-value="satellite">Satellite</button>
              <button class="theme-btn" data-value="terrain">Relief</button>
            </div>
          </div>
        </div>

      </div><!-- /#settings-panel -->

      <!-- ─── MAP PANEL ───────────────────────────────────────────────────── -->
      <div id="map-panel" style="display:none;flex-direction:column;height:100%;overflow:hidden;">

        <!-- Transport mode -->
        <div class="panel-section">
          <p class="section-label">Mode de transport (segments route)</p>
          <div style="display:flex;gap:6px;">
            <button id="btn-transport-driving" class="transport-btn active" title="Voiture">🚗 Voiture</button>
            <button id="btn-transport-walking" class="transport-btn" title="À pied">🚶 Pied</button>
            <button id="btn-transport-bicycling" class="transport-btn" title="Vélo">🚴 Vélo</button>
          </div>
        </div>

        <!-- Layer panel -->
        <div class="panel-section" style="flex-shrink:0;">
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <p class="section-label" style="margin:0;">Polygones</p>
            <button id="btn-add-polygon" class="btn btn-secondary"
                    style="font-size:0.72rem;padding:3px 8px;" disabled>
              + Nouveau
            </button>
          </div>
          <div id="polygon-layer-list" style="margin-top:6px;display:flex;flex-direction:column;gap:3px;"></div>
        </div>

        <!-- Waypoints list -->
        <div class="panel-section" style="flex:1;overflow-y:auto;min-height:80px;">
          <p class="section-label">Points de passage</p>
          <div id="waypoint-list" style="display:flex;flex-direction:column;gap:4px;">
            <p style="font-size:0.75rem;color:var(--color-text-muted);font-style:italic;text-align:center;padding:8px 0;">
              Clique sur la carte pour ajouter des points
            </p>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="panel-section" style="display:flex;flex-direction:column;gap:6px;">
          <div style="display:flex;gap:6px;">
            <button id="btn-undo" class="btn btn-secondary" style="flex:1;" disabled>
              ↩ Supprimer dernier
            </button>
            <button id="btn-clear" class="btn btn-danger" disabled>🗑</button>
          </div>
          <button id="btn-export-kml" class="btn btn-blue" style="width:100%;" disabled>
            📄 Exporter KML
          </button>
        </div>

        <!-- KML export panel (collapsible) -->
        <div id="kml-panel" style="display:none;padding:12px 16px;border-top:1px solid var(--color-border);flex-direction:column;gap:8px;">
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <p class="section-label" style="margin:0;">KML Polygon</p>
            <button id="btn-kml-close" style="background:none;border:none;color:var(--color-text-muted);cursor:pointer;font-size:1rem;padding:0;line-height:1;">×</button>
          </div>
          <div id="kml-stats" style="font-size:0.72rem;color:var(--color-text-muted);"></div>
          <textarea
            id="kml-output"
            class="kml-textarea"
            rows="8"
            readonly
            spellcheck="false"
          ></textarea>
          <div style="display:flex;gap:6px;">
            <button id="btn-kml-copy" class="btn btn-secondary" style="flex:1;font-size:0.78rem;">
              📋 Copier
            </button>
            <button id="btn-kml-download" class="btn btn-primary" style="flex:1;font-size:0.78rem;">
              ⬇ Télécharger .kml
            </button>
          </div>
        </div>

      </div><!-- /#map-panel -->

    </aside><!-- /aside -->

    <!-- ═══════════════════════════════════════════════════════════════════════
         MAP AREA
    ══════════════════════════════════════════════════════════════════════════ -->
    <main style="position:relative;flex:1;overflow:hidden;">

      <!-- Segment mode toggle -->
      <div style="position:absolute;top:16px;left:50%;transform:translateX(-50%);z-index:10;">
        <div class="toggle-pill" id="segment-toggle">
          <button id="btn-mode-route" class="toggle-pill-btn active-route">🛣 Trajet</button>
          <button id="btn-mode-straight" class="toggle-pill-btn inactive">✈ Vol d'oiseau</button>
        </div>
      </div>

      <!-- Snap toggle -->
      <button
        id="btn-snap-toggle"
        class="snap-btn"
        title="Outil aimant — accroche les nouveaux points sur les tracés existants"
        style="position:absolute;top:16px;right:16px;z-index:10;"
      >🧲</button>

      <!-- Map loading overlay -->
      <div id="map-loading" class="loading-overlay" style="display:none;">
        <div class="spinner"></div>
        <p style="font-size:0.85rem;color:var(--color-text-muted);margin:0;">Chargement de la carte…</p>
      </div>

      <!-- Hint overlay -->
      <div
        id="map-hint"
        style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);z-index:5;pointer-events:none;"
      >
        <div style="background:rgba(26,29,39,0.85);border:1px solid var(--color-border);border-radius:8px;padding:8px 16px;font-size:0.78rem;color:var(--color-text-muted);white-space:nowrap;backdrop-filter:blur(4px);">
          <span id="map-hint-text">Clique sur la carte pour placer un point de passage</span>
        </div>
      </div>

      <!-- Google Maps container -->
      <div id="map" style="height:100%;width:100%;"></div>

    </main>

  </body>
</html>

<script>
  import { RouteUI } from "../components/RouteUI.ts";

  const ui = new RouteUI();
  ui.init().catch(console.error);

  // Hint text is managed dynamically by RouteUI
</script>
