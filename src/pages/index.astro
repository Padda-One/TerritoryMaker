        </div>
      </div>

      <!-- ─── Right toolbar ──────────────────────────────────────────────── -->
      <div
        style="position:absolute;top:16px;right:16px;z-index:1000;display:flex;flex-direction:column;gap:6px;"
      >
        <!-- Snap -->
        <button
          id="btn-snap-toggle"
          class="snap-btn"
          title="Outil aimant — accroche les nouveaux points sur les tracés existants"
          >🧲</button
        >

        <!-- Map provider -->
        <button
          id="btn-provider-toggle"
          class="snap-btn"
          title="Basculer le fournisseur de carte (OpenStreetMap = affichage uniquement, calcul des trajets toujours via Google)"
          style=""
          ><img
            id="btn-provider-icon"
            src="/gm.avif"
            alt="Google Maps"
            style="width:22px;height:22px;display:block;border-radius:3px;"
          /></button
        >

        <!-- Vertex edit (visible when an imported polygon is active) -->
        <button
          id="btn-vertex-edit"
          class="snap-btn"
          title="Éditer les coordonnées du polygone importé"
          style="display:none;"
          ><img
            src="/images/tools/pencil.svg"
            width="20"
            height="20"
            alt=""
            aria-hidden="true"
          /></button
        >

        <!-- Split (visible when a closed polygon is active) -->
        <button id="btn-split" class="snap-btn" title="Découper le polygone" style="display:none;">✂</button>

        <!-- Merge (visible when exactly 2 polygons are selected) -->
        <button id="btn-merge" class="snap-btn" title="Fusionner les polygones sélectionnés" style="display:none;">⊕</button>

        <!-- Undo Split/Merge -->
        <button id="btn-undo-split-merge" class="snap-btn" title="Annuler la dernière opération Split/Merge" style="display:none;">↩</button>
      </div>

      <!-- Map loading overlay -->
      <div id="map-loading" class="loading-overlay" style="display:none;">
        <div class="spinner"></div>
        <p style="font-size:0.85rem;color:var(--color-text-muted);margin:0;">
          Chargement de la carte…
        </p>
      </div>

      <!-- Hint overlay -->
      <div
        id="map-hint"
        style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);z-index:1000;pointer-events:none;"
      >
        <div class="map-hint-inner">
          <span id="map-hint-text"
            >Cliquez sur la carte pour placer un point de passage</span
          >
        </div>
      </div>

      <!-- Google Maps / Leaflet container -->
      <div id="map" style="height:100%;width:100%;position:relative;z-index:0;">
      </div>
    </main>

    <!-- Context menu for layer panel -->
    <div
      id="layer-ctx-menu"
      class="ctx-menu"
      role="menu"
      aria-label="Actions"
      hidden
    >
    </div>
  </body>
</html>

<script>
  import { RouteUI } from "../components/RouteUI.ts";

  const ui = new RouteUI();
  ui.init().catch(console.error);

  // Hamburger menu
  const hamburger = document.getElementById("lp-hamburger")!;
  const navLinks = document.getElementById("lp-nav-links")!;
  hamburger.addEventListener("click", () => {
    const open = navLinks.classList.toggle("open");
    hamburger.classList.toggle("open", open);
    hamburger.setAttribute("aria-expanded", String(open));
  });
  navLinks.querySelectorAll("a, button").forEach((el) =>
    el.addEventListener("click", () => {
      navLinks.classList.remove("open");
      hamburger.classList.remove("open");
      hamburger.setAttribute("aria-expanded", "false");
    })
  );
  document.addEventListener("click", (e) => {
    if (!hamburger.contains(e.target as Node) && !navLinks.contains(e.target as Node)) {
      navLinks.classList.remove("open");
      hamburger.classList.remove("open");
      hamburger.setAttribute("aria-expanded", "false");
    }
  });

  // Scroll-reveal via IntersectionObserver
  const revealObserver = new IntersectionObserver(
    (entries) =>
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("active");
          revealObserver.unobserve(e.target);
        }
      }),
    { threshold: 0.08 },
  );
  document
    .querySelectorAll(".reveal")
    .forEach((el) => revealObserver.observe(el));
</script>
