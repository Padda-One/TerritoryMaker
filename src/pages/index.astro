          <!-- Filter (visible once polygons are loaded) -->
          <input
            id="layer-filter"
            type="search"
            placeholder="Filtrer les polygones…"
            style="margin-top:6px;width:100%;font-size:0.75rem;background:var(--color-surface-2);color:var(--color-text);border:1px solid var(--color-border);border-radius:4px;padding:3px 7px;outline:none;box-sizing:border-box;"
          />
