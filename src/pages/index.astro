          </div>
          <!-- Import progress bar (hidden by default) -->
          <div id="import-progress" style="display:none;margin-top:6px;">
            <p
              id="import-progress-text"
              style="font-size:0.7rem;color:var(--color-text-muted);margin:0 0 3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
            >
            </p>
            <div
              style="height:3px;background:var(--color-border);border-radius:2px;"
