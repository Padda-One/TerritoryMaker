---
import "../styles/global.css";
import "leaflet/dist/leaflet.css";
---

<!doctype html>
<html lang="fr" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href="https://territory.paddaone.com/" />

    <!-- SEO -->
    <title>Territory Maker — Tracez et exportez vos territoires en KML</title>
    <meta name="description" content="Outil web client-side pour délimiter des territoires sur Google Maps : tracé routier ou vol d'oiseau, gestion multi-polygones, import/export KML. Sans tracking, clé API chiffrée localement. Open source MIT." />
    <meta name="author" content="Paddaone" />
    <meta name="keywords" content="territory maker, tracé territoire, carte territoire, KML export, Google Maps territoire, polygone KML, cartographie territoire, QGIS KML, territoire géographique" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://territory.paddaone.com/" />
    <meta property="og:site_name" content="Territory Maker" />
    <meta property="og:title" content="Territory Maker — Tracez et exportez vos territoires en KML" />
    <meta property="og:description" content="Délimitez des territoires sur Google Maps avec précision. Tracé routier ou vol d'oiseau, export KML vers Google Earth et QGIS. 100% client-side, sans tracking." />
    <meta property="og:image" content="https://territory.paddaone.com/og-preview.png" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Territory Maker — Tracez et exportez vos territoires en KML" />
    <meta name="twitter:description" content="Délimitez des territoires sur Google Maps. Export KML. 100% client-side, sans tracking." />
    <meta name="twitter:image" content="https://territory.paddaone.com/og-preview.png" />

    <!-- Structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Territory Maker",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Web Browser",
      "url": "https://territory.paddaone.com",
      "description": "Outil web client-side pour délimiter des territoires géographiques sur Google Maps. Combine segments routiers (Google Directions API) et lignes droites. Gestion multi-polygones avec dossiers, import/export KML vers Google Earth et QGIS. Clé API chiffrée localement (AES-GCM 256-bit). Zéro tracking, zéro backend.",
      "featureList": [
        "Tracé routier via Google Directions API",
        "Tracé en ligne droite (vol d'oiseau)",
        "Gestion multi-polygones et dossiers",
        "Import et export KML",
        "Compatibilité Google Earth et QGIS",
        "Chiffrement local AES-GCM 256-bit",
        "Sans tracking publicitaire",
        "100% client-side",
        "Open source MIT"
      ],
      "author": {
        "@type": "Person",
        "name": "Paddaone",
        "url": "https://github.com/Padda-One"
      },
      "license": "https://opensource.org/licenses/MIT",
      "softwareVersion": "1.0",
      "inLanguage": "fr",
      "isAccessibleForFree": true,
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR"
      },
      "codeRepository": "https://github.com/Padda-One/TerritoryMaker"
    }
    </script>

    <!-- Video structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "VideoObject",
      "name": "Territory Maker — Présentation",
      "description": "Démonstration de Territory Maker : tracé de territoires sur Google Maps, gestion multi-polygones, import/export KML.",
      "thumbnailUrl": "https://territory.paddaone.com/videos/Territory_Maker_poster.avif",
      "uploadDate": "2026-03-24",
      "duration": "PT34S",
      "contentUrl": "https://territory.paddaone.com/videos/Territory_Maker.mp4",
      "embedUrl": "https://territory.paddaone.com/"
    }
    </script>

    <link rel="icon" type="image/svg+xml" href="/logo-TerritoryMaker.svg" />
  </head>

  <body
    style="display:flex;height:100vh;overflow:hidden;background-color:var(--color-bg);color:var(--color-text);"
  >
    <!-- ═══════════════════════════════════════════════════════════════════════
         LANDING PAGE (shown when no API key is stored)
    ══════════════════════════════════════════════════════════════════════════ -->
    <div id="landing-page" aria-label="Présentation de Territory Maker">
      <!-- ── Navigation ────────────────────────────────────────────────────── -->
      <header class="lp-nav">
        <nav class="lp-nav-inner">
          <div class="lp-nav-logo">
            <img
              src="/logo-TerritoryMaker.svg"
              width="50"
              height="50"
              aria-hidden="true"
              class="lp-nav-logo-icon"
            />
            Territory Maker
          </div>
          <div class="lp-nav-links" id="lp-nav-links">
            <a href="/documentation" class="lp-nav-link">Documentation</a>
            <a
              href="https://github.com/Padda-One/TerritoryMaker"
              target="_blank"
              rel="noopener noreferrer"
              class="lp-nav-link">GitHub</a
            >
            <button
              class="lp-nav-cta"
              onclick="document.getElementById('landing-key-input').focus()"
              >Commencer</button
            >
          </div>
          <button class="lp-hamburger" id="lp-hamburger" aria-label="Ouvrir le menu" aria-expanded="false">
            <span class="lp-hamburger-bar"></span>
            <span class="lp-hamburger-bar"></span>
            <span class="lp-hamburger-bar"></span>
          </button>
        </nav>
      </header>

      <!-- ── Hero ─────────────────────────────────────────────────────────── -->
      <main class="lp-main">
        <section class="lp-hero reveal">
          <!-- Left column -->
          <div class="lp-hero-left">
            <div class="lp-space-y-10">
              <div class="lp-space-y-6">
                <span class="lp-badge"
                  >Cartographie de territoires · Export KML</span
                >
                <h1 class="lp-h1">
                  Délimitez vos territoires avec une <span class="lp-h1-accent"
                    >précision absolue</span
                  >.
                </h1>
                <p class="lp-hero-desc">
                  Outil client-side pour le tracé, l'import et l'export de
                  polygones KML. Combinez segments routiers et lignes droites,
                  gérez des centaines de polygones, exportez vers Google Earth
                  et QGIS.
                </p>
                <p class="lp-desktop-notice">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                  Outil conçu pour une utilisation sur ordinateur.
                </p>
              </div>

              <!-- Form card -->
              <div class="glass-card lp-form-card lp-neon-focus">
                <form id="landing-key-form" class="lp-form-inner" novalidate>
                  <div class="lp-form-field">
                    <label for="landing-key-input" class="lp-form-label">
                      Authentification API Google Maps
                    </label>
                    <input
                      id="landing-key-input"
                      type="password"
                      class="lp-form-input"
                      placeholder="Saisir la clé API (AIza…)"
                      autocomplete="off"
                      spellcheck="false"
                      aria-describedby="landing-key-hint"
                      required
                    />
                  </div>
                  <p id="landing-key-hint" class="lp-form-hint">
                    Nécessite <strong>Maps JavaScript API</strong> et <strong
                      >Directions API</strong
                    >.
                  </p>
                  <div
                    id="landing-error"
                    role="status"
                    aria-live="polite"
                    class="landing-error"
                    hidden
                  >
                  </div>
                  <button
                    type="submit"
                    class="lp-submit landing-submit lp-neon-hover"
                  >
                    Initialiser la session
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      ><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg
                    >
                  </button>
                </form>
                <a href="/documentation" class="lp-form-guide"
                  >Procédure d'obtention de la clé API →</a
                >
              </div>
            </div>
          </div>

          <!-- Right column — SVG visualization -->
          <div class="lp-hero-right">
            <video
              class="lp-hero-video"
              autoplay
              muted
              loop
              playsinline
              poster="/videos/Territory_Maker_poster.avif"
              preload="metadata"
              width="390"
              height="844"
            >
              <source src="/videos/Territory_Maker.webm" type="video/webm" />
              <source src="/videos/Territory_Maker.mp4" type="video/mp4" />
            </video>
          </div>
        </section>

        <!-- ── Reliability section ─────────────────────────────────────────── -->
        <section class="lp-reliability reveal">
          <div class="lp-reliability-inner">
            <div class="lp-section-header">
              <h2 class="lp-section-title">Pourquoi l'outil est fiable</h2>
              <p class="lp-section-desc">
                Territory Maker opère en mode isolé. L'architecture garantit la
                protection de vos données et la pérennité du traitement local.
              </p>
            </div>

            <div class="lp-cards-grid">
              <!-- Card 1 -->
              <div class="glass-card lp-feature-card lp-hover-lift">
                <div class="lp-feature-icon-box lp-icon-green">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    ><rect x="4" y="4" width="16" height="16" rx="2"
                    ></rect><rect x="9" y="9" width="6" height="6"></rect><line
                      x1="9"
                      y1="1"
                      x2="9"
                      y2="4"></line><line x1="15" y1="1" x2="15" y2="4"
                    ></line><line x1="9" y1="20" x2="9" y2="23"></line><line
                      x1="15"
                      y1="20"
                      x2="15"
                      y2="23"></line><line x1="20" y1="9" x2="23" y2="9"
                    ></line><line x1="20" y1="14" x2="23" y2="14"></line><line
                      x1="1"
                      y1="9"
                      x2="4"
                      y2="9"></line><line x1="1" y1="14" x2="4" y2="14"
                    ></line></svg
                  >
                </div>
                <div class="lp-feature-text">
                  <h3 class="lp-feature-title">Exécution Locale</h3>
                  <p class="lp-feature-desc">
                    Moteur 100% statique. Le traitement s'effectue exclusivement
                    dans le runtime du navigateur, sans transit serveur.
                  </p>
                </div>
              </div>
              <!-- Card 2 -->
              <div class="glass-card lp-feature-card lp-hover-lift">
                <div class="lp-feature-icon-box lp-icon-blue">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    ><rect x="3" y="11" width="18" height="11" rx="2"
                    ></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
                  >
                </div>
                <div class="lp-feature-text">
                  <h3 class="lp-feature-title">Persistence Isolée</h3>
                  <p class="lp-feature-desc">
                    La clé API est chiffrée AES-GCM 256 bits dans le
                    localStorage. Elle ne quitte jamais votre navigateur.
                  </p>
                </div>
              </div>
              <!-- Card 3 -->
              <div class="glass-card lp-feature-card lp-hover-lift">
                <div class="lp-feature-icon-box lp-icon-green">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    ><path
                      d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"
                    ></path><line x1="1" y1="1" x2="23" y2="23"></line></svg
                  >
                </div>
                <div class="lp-feature-text">
                  <h3 class="lp-feature-title">Zéro Tracking</h3>
                  <p class="lp-feature-desc">
                    Aucun cookie, aucune balise tierce. Les
                    données restent rigoureusement limitées aux requêtes
                    cartographiques.
                  </p>
                </div>
              </div>
              <!-- Card 4 -->
              <div class="glass-card lp-feature-card lp-hover-lift">
                <div class="lp-feature-icon-box lp-icon-blue">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    ><polyline points="16 18 22 12 16 6"></polyline><polyline
                      points="8 6 2 12 8 18"></polyline></svg
                  >
                </div>
                <div class="lp-feature-text">
                  <h3 class="lp-feature-title">Audit Open Source</h3>
                  <p class="lp-feature-desc">
                    Code source public et auditable en continu sur <a
                      href="https://github.com/Padda-One/TerritoryMaker"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="lp-inline-link">GitHub</a
                    >. Transparence totale sur les algorithmes.
                  </p>
                </div>
              </div>
            </div>

            <!-- Technical note -->
            <div class="glass-card lp-tech-note">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="lp-tech-note-icon"
                ><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path
                  d="M1.42 9a16 16 0 0 1 21.16 0"></path><path
                  d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><line
                  x1="12"
                  y1="20"
                  x2="12.01"
                  y2="20"></line></svg
              >
              <p class="lp-tech-note-text">
                Architecture technique : les tuiles cartographiques sont
                établies en liaison directe entre votre navigateur et les
                endpoints des fournisseurs (Google Maps / OpenStreetMap) via
                authentification par clé API. Aucun proxy de notre part.
              </p>
            </div>
          </div>
        </section>
      </main>

      <!-- ── Footer ────────────────────────────────────────────────────────── -->
      <footer class="lp-footer">
        <div class="lp-footer-inner">
          <div class="lp-footer-brand">
            <div class="lp-footer-logo">
              <img
                src="/logo-TerritoryMaker.svg"
                width="50"
                height="50"
                aria-hidden="true"
              />
              Territory Maker
            </div>
            <div class="lp-footer-version">Système de cartographie KML</div>
          </div>
          <div class="lp-footer-links">
            <button
              class="lp-footer-link"
              onclick="document.getElementById('legal-modal').style.display='flex'"
              >Mentions Légales</button
            >
            <a
              href="https://github.com/Padda-One/TerritoryMaker"
              target="_blank"
              rel="noopener noreferrer"
              class="lp-footer-link">GitHub</a
            >
            <a href="/documentation" class="lp-footer-link">Documentation</a>
          </div>
          <div class="lp-footer-copy">
            Fait avec ❤️ par <a
              href="https://paddaone.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="lp-footer-paddaone"
              ><img
                src="/paddaone-logo.avif"
                alt="Paddaone"
                class="lp-footer-brand-logo"
                width="16"
                height="16"
              />Paddaone</a
            >
          </div>
        </div>
      </footer>
    </div><!-- /#landing-page -->

    <!-- ── Legal modal (outside #landing-page to avoid overflow clipping) ──── -->
    <div
      id="legal-modal"
      class="lp-modal"
      style="display:none"
      onclick="if(event.target===this)this.style.display='none'"
    >
      <div class="lp-modal-card">
        <button
          class="lp-modal-close"
          onclick="document.getElementById('legal-modal').style.display='none'"
          aria-label="Fermer"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            ><line x1="18" y1="6" x2="6" y2="18"></line><line
              x1="6"
              y1="6"
              x2="18"
              y2="18"></line></svg
          >
        </button>
        <div class="lp-modal-body">
          <h2 class="lp-modal-title">Protocole Légal</h2>
          <div class="legal-section">
            <h3 class="legal-section-title">Entité Éditrice</h3>
            <p>
              Plateforme opérée par <strong
                style="color:var(--color-accent-blue)">Padda-One</strong
              >.
            </p>
          </div>
          <div class="legal-section">
            <h3 class="legal-section-title">Infrastructures</h3>
            <p>
              Déploiement via infrastructure statique <strong
                style="color:var(--color-accent-blue)">GitHub Pages</strong
              > (GitHub Inc.). Aucun serveur applicatif.
            </p>
          </div>
          <div class="legal-section">
            <h3 class="legal-section-title">Données Personnelles</h3>
            <p>
              Aucune donnée personnelle n'est collectée, traitée ou transmise.
              Les configurations sont encapsulées dans le périmètre local du
              navigateur.
            </p>
          </div>
          <div class="legal-section">
            <h3 class="legal-section-title">Clé API</h3>
            <p>
              Votre clé Google Maps API est stockée uniquement dans votre
              navigateur, chiffrée AES-GCM 256 bits. Elle n'est jamais transmise
              à l'éditeur ni à un tiers.
            </p>
          </div>
          <div class="legal-section">
            <h3 class="legal-section-title">Cookies</h3>
            <p>Aucun cookie d'aucune sorte.</p>
          </div>
          <div class="legal-section">
            <h3 class="legal-section-title">Données Cartographiques</h3>
            <p>
              Tuiles fournies par Google Maps API et/ou OpenStreetMap. ©
              Contributeurs OpenStreetMap, licence <a
                href="https://opendatacommons.org/licenses/odbl/"
                target="_blank"
                rel="noopener noreferrer"
                class="lp-inline-link">ODbL</a
              >.
            </p>
          </div>
          <div class="legal-section">
            <h3 class="legal-section-title">Code Source</h3>
            <p>
              Public et auditable sur <a
                href="https://github.com/Padda-One/TerritoryMaker"
                target="_blank"
                rel="noopener noreferrer"
                class="lp-inline-link">GitHub — https://github.com/Padda-One/TerritoryMaker</a
              >.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SIDEBAR
    ══════════════════════════════════════════════════════════════════════════ -->
    <aside id="sidebar" class="sidebar">
      <!-- Header -->
      <div class="sidebar-header">
        <div style="display:flex;align-items:center;gap:8px;">
          <img src="/logo-TerritoryMaker.svg" width="50" height="50" alt="" />
          <div>
            <h1
              style="font-size:0.95rem;font-weight:700;color:var(--color-text);margin:0;line-height:1.2;"
            >
              Territory Maker
            </h1>
            <p
              style="font-size:0.68rem;color:var(--color-text-muted);margin:1px 0 0;"
            >
              Tracez · Exportez · KML
            </p>
          </div>
        </div>
        <button id="btn-settings-toggle" class="btn-icon" title="Paramètres"
          >⚙</button
        >
      </div>

      <!-- ─── SETTINGS PANEL ──────────────────────────────────────────────── -->
      <div
        id="settings-panel"
        style="display:flex;flex-direction:column;flex:1;overflow-y:auto;"
      >
        <!-- API Key section -->
        <div class="settings-section">
          <p class="settings-section-title">Clé Google Maps API</p>

          <!-- Key form (shown when no key stored) -->
          <div
            id="key-form-section"
            style="display:flex;flex-direction:column;gap:10px;"
          >
            <p
              style="font-size:0.75rem;color:var(--color-text-muted);margin:0;line-height:1.5;"
            >
              Nécessite l'activation de <strong style="color:var(--color-text);"
                >Maps JavaScript API</strong
              >
              et <strong style="color:var(--color-text);">Directions API</strong
              >.
            </p>
            <a href="/documentation" class="guide-link">
              📖 Pas encore de clé ? Guide pas à pas →
            </a>
            <form
              id="key-form"
              style="display:flex;flex-direction:column;gap:8px;"
            >
              <input
                id="key-input"
                type="password"
                class="input-dark"
                placeholder="AIza…"
                autocomplete="off"
                spellcheck="false"
                required
              />
              <button type="submit" class="btn btn-primary" style="width:100%;">
                Charger la carte
              </button>
            </form>
          </div>

          <!-- Key status (shown when key is stored) -->
          <div
            id="key-stored-section"
            style="display:none;flex-direction:column;gap:10px;"
          >
            <div class="key-status-box">
              <span style="font-size:1.2rem;">🔑</span>
              <div>
                <strong style="font-size:0.82rem;color:var(--color-text);"
                  >Clé API enregistrée</strong
                >
                <p
                  style="margin:3px 0 0;font-size:0.73rem;color:var(--color-text-muted);"
                >
                  Chiffrée localement (AES-GCM 256 bits).
                </p>
              </div>
            </div>
            <a href="/documentation" class="guide-link">
              📖 Consulter la documentation →
            </a>
            <button
              id="btn-forget-key"
              class="btn btn-danger"
              style="width:100%;font-size:0.78rem;"
            >
              🗝 Oublier la clé API
            </button>
          </div>

          <!-- Security notices -->
          <div class="notice-box">
            <div style="display:flex;gap:6px;align-items:flex-start;">
              <span style="font-size:1rem;flex-shrink:0;">🔒</span>
              <div>
                <strong style="color:var(--color-text);font-size:0.78rem;"
                  >Stockage local chiffré</strong
                >
                <p style="margin:4px 0 0;font-size:0.73rem;">
                  Ta clé reste sur ton appareil. Elle n'est jamais envoyée à nos
                  serveurs.
                </p>
              </div>
            </div>
          </div>
          <div class="notice-box notice-box-warning">
            <div style="display:flex;gap:6px;align-items:flex-start;">
              <span style="font-size:1rem;flex-shrink:0;">⚠️</span>
              <div>
                <strong
                  style="color:var(--color-accent-yellow);font-size:0.78rem;"
                  >Restreins ta clé API</strong
                >
                <p
