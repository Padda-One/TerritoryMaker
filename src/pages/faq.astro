    <link rel="icon" type="image/svg+xml" href="/logo-TerritoryMaker.svg" />

    <!-- Plausible Analytics (auto-hébergé, proxifié via Cloudflare Worker) -->
    <script
      defer
      data-domain="territory.paddaone.com"
      data-api="https://territory.paddaone.com/3wpjej9/event"
      src="https://territory.paddaone.com/3wpjej9/script.outbound-links.js"
      crossorigin="anonymous"></script>
  </head>

  <body>
    <!-- Header -->
    <header class="doc-header">
      <div class="doc-header-inner">
        <a href="/" class="doc-back-link">
          <span>←</span>Retour à l'app
        </a>
        <span class="doc-header-divider">|</span>
        <div class="doc-header-logo">
          <img src="/logo-TerritoryMaker.svg" width="50" height="50" alt="" />
          <span>Territory Maker</span>
        </div>
        <button
          class="sidebar-mobile-btn"
          id="sidebarToggle"
          aria-label="Ouvrir la navigation"
        >
          ☰ Catégories
        </button>
      </div>
    </header>

    <!-- Mobile backdrop -->
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    <!-- FAQ layout -->
    <div class="doc-layout">
      <!-- Sidebar -->
      <nav class="doc-sidebar" id="docSidebar" aria-label="Catégories FAQ">
        <div class="sidebar-label">Catégories</div>
        <ol class="sidebar-nav">
          <li>
            <a href="#cat-trace" class="sidebar-chapter-link">
              <span class="sidebar-num">A</span>
              <span>Tracé et dessin</span>
            </a>
          </li>
          <li>
            <a href="#cat-calques" class="sidebar-chapter-link">
              <span class="sidebar-num">B</span>
              <span>Calques et territoires</span>
            </a>
          </li>
          <li>
            <a href="#cat-export" class="sidebar-chapter-link">
              <span class="sidebar-num">C</span>
              <span>Export et compatibilité</span>
            </a>
          </li>
          <li>
            <a href="#cat-api" class="sidebar-chapter-link">
              <span class="sidebar-num">D</span>
              <span>Clé API et coûts</span>
            </a>
          </li>
          <li>
            <a href="#cat-donnees" class="sidebar-chapter-link">
              <span class="sidebar-num">E</span>
              <span>Données et navigateur</span>
            </a>
          </li>
        </ol>

        <div
          style="margin-top:32px;padding-top:20px;border-top:1px solid #2d3148;"
        >
          <a
            href="/documentation"
            class="sidebar-chapter-link"
            style="font-size:0.78rem;font-weight:500;"
          >
            → Documentation complète
          </a>
        </div>
      </nav>

      <!-- Content -->
      <main class="doc-content">
        <!-- Title -->
        <div style="margin-bottom:40px;">
          <div
            style="display:inline-flex;align-items:center;gap:8px;background:rgba(0,229,160,0.1);border:1px solid rgba(0,229,160,0.25);border-radius:9999px;padding:4px 14px;font-size:0.75rem;font-weight:600;color:#00e5a0;margin-bottom:16px;"
          >
            FAQ
          </div>
          <h1
            style="font-size:1.75rem;font-weight:800;color:#e2e8f0;margin:0 0 12px;line-height:1.2;"
          >
            Questions fréquentes
          </h1>
          <p style="font-size:0.95rem;color:#94a3b8;margin:0;line-height:1.6;">
            Tout ce qu'il faut savoir pour tracer et exporter vos territoires en
            KML. Pour un guide pas-à-pas, consultez la <a
              href="/documentation"
              style="color:#818cf8;text-decoration:underline;text-underline-offset:2px;"
              >documentation complète</a
            >.
          </p>
        </div>

        <!-- ─── CATÉGORIE A : Tracé et dessin ─── -->
        <section id="cat-trace" style="margin-bottom:56px;">
          <div class="chapter-header">
            <div class="chapter-number">A</div>
            <h2 class="chapter-title">Tracé et dessin</h2>
          </div>

          <div class="doc-section">
            <div class="faq-item" id="faq-a1">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-a1-body"
              >
                <span class="faq-q-text"
                  >Mon tracé est bizarre / ne suit pas la bonne route</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-a1-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    Le mode <strong>Trajet</strong> respecte le sens de circulation.
                    Si vous cliquez depuis la mauvaise rive d'une rue à sens unique,
                    l'itinéraire contourne le bloc.
                  </p>
                  <p><strong>Solutions :</strong></p>
                  <ul class="step-list">
                    <li>
                      Positionnez-vous <strong>à droite de la chaussée</strong> avant
                      de cliquer (dans les pays où l'on conduit à droite)
                    </li>
                    <li>
                      Changez le <strong>mode de transport</strong> (à pied ou à vélo)
                      pour ce tronçon délicat
                    </li>
                    <li>
                      Passez en <strong>Vol d'oiseau</strong> pour tracer une ligne
                      droite sur ce segment
                    </li>
                    <li>
                      Ajoutez des <strong>points intermédiaires</strong> de chaque
                      côté du sens unique
                    </li>
                  </ul>
                  <p>
                    Rappel : chaque segment peut utiliser un mode différent. Un <strong
                      >double-clic</strong
                    > sur un waypoint existant permet de le déplacer.
                  </p>
                  <div class="faq-img-row">
                    <button
                      class="faq-thumb-btn"
                      data-lightbox-src="/images/captures/trace-bizarre.avif"
                      data-lightbox-alt="Exemple de tracé bizarre dû à un sens unique"
                      aria-label="Agrandir : exemple de tracé bizarre"
                    >
                      <img
                        src="/images/captures/trace-bizarre.avif"
                        alt="Exemple de tracé bizarre dû à un sens unique"
                        class="faq-thumb"
                        loading="lazy"
                      />
                      <span class="faq-thumb-caption">Tracé bizarre</span>
                    </button>
                    <button
                      class="faq-thumb-btn"
                      data-lightbox-src="/images/captures/trace-corrige.avif"
                      data-lightbox-alt="Tracé corrigé après repositionnement du point"
                      aria-label="Agrandir : tracé corrigé"
                    >
                      <img
                        src="/images/captures/trace-corrige.avif"
                        alt="Tracé corrigé après repositionnement du point"
                        class="faq-thumb"
                        loading="lazy"
                      />
                      <span class="faq-thumb-caption">Tracé corrigé</span>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <div class="faq-item" id="faq-a2">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-a2-body"
              >
                <span class="faq-q-text"
                  >Quelle est la différence entre Trajet et Vol d'oiseau ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-a2-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    <span class="api-badge api-badge-green">Trajet</span> suit le
                    réseau routier via l'API Google Directions. Idéal pour les frontières
                    de quartier qui longent des rues.
                  </p>
                  <p>
                    <span class="api-badge api-badge-blue">Vol d'oiseau</span> relie
                    deux points en ligne droite. Utile pour les limites naturelles
                    (rivières, voies ferrées, terrains vagues) ou pour contourner
                    un sens unique problématique.
                  </p>
                  <p>
                    Chaque segment est indépendant : le mode actif dans la barre
                    d'outils s'applique uniquement au prochain clic.
                  </p>
                </div>
              </div>
            </div>

            <div class="faq-item" id="faq-a3">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-a3-body"
              >
                <span class="faq-q-text"
                  >Comment fermer / terminer un polygone ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-a3-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    Cliquez sur le <strong>premier point</strong> du tracé pour fermer
                    le polygone, ou utilisez le bouton <strong>Fermer</strong> dans
                    la barre d'outils.
                  </p>
                  <p>
                    Une fois fermé, le polygone devient un <span
                      class="api-badge api-badge-green">Tracé</span
                    >. Il reste éditable sommet par sommet via le bouton <strong
                      >Éditer (✏)</strong
                    >.
                  </p>
                </div>
              </div>
            </div>

            <div class="faq-item" id="faq-a4">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-a4-body"
              >
                <span class="faq-q-text"
                  >Comment annuler la dernière action ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-a4-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    <kbd>Ctrl</kbd>+<kbd>Z</kbd> (ou <kbd>Cmd</kbd>+<kbd>Z</kbd> sur
                    Mac) annule le dernier point posé.
                  </p>
                  <p>
                    Le bouton <strong>↩</strong> dans la barre d'outils annule les
                    opérations Split et Merge.
                  </p>
                  <div class="step-notice step-notice-warning">
                    <span style="flex-shrink:0;">⚠️</span>
                    <span
                      >Il n'y a pas de Redo (Ctrl+Y). Si vous annulez trop loin,
                      recommencez depuis le dernier point conservé.</span
                    >
                  </div>
                </div>
              </div>
            </div>

            <div class="faq-item" id="faq-a5">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-a5-body"
              >
                <span class="faq-q-text"
                  >Comment utiliser l'outil Snap (aimant 🧲) ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-a5-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    L'outil <strong>Snap</strong> (icône aimant 🧲, jaune quand actif)
                    force le prochain clic à s'accrocher au sommet le plus proche
                    d'un polygone voisin.
                  </p>
                  <p>
                    Il permet à deux territoires de partager <strong
                      >exactement la même frontière</strong
                    >
                    sans espace ni chevauchement — indispensable pour un découpage
                    propre d'une ville.
                  </p>
                  <p>
                    Cliquez le bouton aimant 🧲 dans la barre d'outils pour
                    l'activer manuellement. Il s'active aussi automatiquement
                    lors d'une opération Split.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- ─── CATÉGORIE B : Calques et territoires ─── -->
        <section id="cat-calques" style="margin-bottom:56px;">
          <div class="chapter-header">
            <div class="chapter-number">B</div>
            <h2 class="chapter-title">Calques et territoires</h2>
          </div>

          <div class="doc-section">
            <div class="faq-item" id="faq-b1">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-b1-body"
              >
                <span class="faq-q-text"
                  >Comment créer plusieurs territoires ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-b1-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    Chaque territoire est un <strong>calque distinct</strong>.
                    Cliquez sur <strong>+</strong> dans le panneau Polygones pour
                    ajouter un calque et lui donner un nom.
                  </p>
                  <p>
                    Cliquez sur un calque pour le <strong>sélectionner</strong> :
                    tous les clics sur la carte s'appliquent au calque actif.
                  </p>
                  <p>
                    Les calques peuvent être organisés en <strong
                      >dossiers</strong
                    >
                    via le menu contextuel (clic droit dans le panneau).
                  </p>
                </div>
              </div>
            </div>

            <div class="faq-item" id="faq-b2">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-b2-body"
              >
                <span class="faq-q-text"
                  >Comment importer un fichier KML existant ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-b2-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    Cliquez sur le bouton <strong>Importer (⬆)</strong> dans l'en-tête
                    du panneau Polygones et sélectionnez un fichier <code
                      >.kml</code
                    >.
                  </p>
                  <p>
                    Tous les polygones sont regroupés dans un dossier portant le
                    nom du fichier. Ils apparaissent comme des <span
                      class="api-badge api-badge-amber">Zones</span
                    >
                    — ils n'ont pas de waypoints ni de segments routiers.
                  </p>
                  <div class="step-notice">
                    <span style="flex-shrink:0;">ℹ️</span>
                    <span
                      >L'import a été testé avec des fichiers contenant jusqu'à
                      835 polygones.</span
                    >
                  </div>
                </div>
              </div>
            </div>

            <div class="faq-item" id="faq-b3">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-b3-body"
              >
                <span class="faq-q-text"
                  >Quelle est la différence entre un Tracé et une Zone ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-b3-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    <span class="api-badge api-badge-green">Tracé</span> — polygone
                    dessiné dans l'application. Conserve ses waypoints et peut recalculer
                    ses segments routiers. Éditable sommet par sommet.
                  </p>
                  <p>
                    <span class="api-badge api-badge-amber">Zone</span> — liste plate
                    de coordonnées brutes. Provient d'un import KML ou de la conversion
                    d'un Tracé fermé. Peut être simplifiée.
                  </p>
                  <div class="step-notice step-notice-warning">
                    <span style="flex-shrink:0;">⚠️</span>
                    <span
                      >La conversion Tracé → Zone est <strong
                        >irréversible</strong
                      >.</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- ─── CATÉGORIE C : Export et compatibilité ─── -->
        <section id="cat-export" style="margin-bottom:56px;">
          <div class="chapter-header">
            <div class="chapter-number">C</div>
            <h2 class="chapter-title">Export et compatibilité</h2>
          </div>

          <div class="doc-section">
            <div class="faq-item" id="faq-c1">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-c1-body"
              >
                <span class="faq-q-text"
                  >À quoi sert le bouton "Simplifier" (⬡) ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-c1-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    Il réduit le nombre de sommets d'une Zone via l'algorithme
                    <strong>Douglas-Peucker</strong>, en supprimant les points
                    redondants tout en conservant la forme générale du polygone.
                  </p>
                  <p>
                    Chaque clic sur le bouton <strong
                      >double la tolérance</strong
                    >
                    (simplification progressive). Le bouton <strong>↺</strong> permet
                    de restaurer les coordonnées d'origine à tout moment.
                  </p>
                  <p><strong>Pourquoi simplifier ?</strong></p>
                  <p>
                    Les polygones issus du mode Trajet accumulent de nombreux
                    points (environ 1 par mètre parcouru). Sur de grands
                    territoires, un fichier KML non simplifié peut contenir des
                    dizaines de milliers de coordonnées. Cela peut ralentir
                    significativement — voire bloquer l'import dans — Google
                    Earth, QGIS ou tout autre logiciel utilisant des fichiers
                    KML. En cas d'utilisation de nombreux territoires,
                    simplifier avant l'export est fortement recommandé.
                  </p>
                </div>
              </div>
            </div>

            <div class="faq-item" id="faq-c2">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-c2-body"
              >
                <span class="faq-q-text"
                  >Avec quels logiciels puis-je utiliser le fichier KML exporté
                  ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-c2-body" hidden>
                <div class="faq-answer-inner step-body">
                  <ul class="step-list">
                    <li>
                      <strong>Google My Maps</strong> — import direct via "Ajouter
                      une couche"
                    </li>
                    <li>
                      <strong>Google Earth</strong> — File → Import ou glisser-déposer
                      du fichier
                    </li>
                    <li>
                      <strong>QGIS</strong> — Couche → Ajouter une couche vectorielle
                      (format KML/KMZ)
                    </li>
                    <li>
                      <strong>New World Scheduler (NWS)</strong> — Territoires → Import
                      → Territories from Google KML
                    </li>
                    <li>
                      <strong>Territory Helper</strong> — Territoires → Edition →
                      Bouton d'importation
                    </li>
                    <li>
                      Tout autre SIG ou logiciel de cartographie supportant le
                      format <strong>KML/KMZ</strong> (standard OGC)
                    </li>
                  </ul>
                  <div class="step-notice step-notice-warning">
                    <span style="flex-shrink:0;">⚠️</span>
                    <span
                      >Pour les fichiers contenant de nombreux polygones ou de
                      grande taille, utilisez la fonction Simplifier avant
                      l'export pour éviter les ralentissements.</span
                    >
                  </div>
                </div>
              </div>
            </div>

            <div class="faq-item" id="faq-c3">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-c3-body"
              >
                <span class="faq-q-text">Comment exporter mon travail ?</span>
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-c3-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>Il existe trois niveaux d'export :</p>
                  <ul class="step-list">
                    <li>
                      <strong>Carte entière</strong> — bouton <strong>
                        🗺 Exporter la carte
                      </strong>
                      dans la barre latérale. Inclut tous les polygones fermés, quel
                      que soit leur dossier. Choisissez ensuite <strong
                        >Copier</strong
                      >
                      (presse-papier) ou <strong>Télécharger</strong> (fichier <code
                        >.kml</code
                      >).
                    </li>
                    <li>
                      <strong>Un dossier</strong> — bouton <strong>⬇</strong> à droite
                      du nom du dossier dans le panneau des calques. Exporte uniquement
                      les polygones de ce dossier.
                    </li>
                    <li>
                      <strong>Un seul polygone</strong> — bouton <strong
                        >⬇</strong
                      >
                      à droite du nom du polygone. Exporte ce polygone uniquement.
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- ─── CATÉGORIE D : Clé API et coûts ─── -->
        <section id="cat-api" style="margin-bottom:56px;">
          <div class="chapter-header">
            <div class="chapter-number">D</div>
            <h2 class="chapter-title">Clé API et coûts</h2>
          </div>

          <div class="doc-section">
            <div class="faq-item" id="faq-d1">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-d1-body"
              >
                <span class="faq-q-text"
                  >La clé API Google Maps est-elle payante ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-d1-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    Google offre <strong
                      >200 $ de crédits gratuits par mois</strong
                    > pour tous les comptes. L'API Directions coûte environ 0,005
                    $ par requête — il faudrait
                    <strong>40 000 segments calculés</strong> pour atteindre le seuil
                    de facturation.
                  </p>
                  <p>
                    Un usage normal de Territory Maker (quelques centaines de
                    territoires) reste largement dans la limite gratuite.
                  </p>
                  <div class="step-notice">
                    <span style="flex-shrink:0;">ℹ️</span>
                    <span
                      >Vous pouvez surveiller votre consommation dans la console
                      Google Cloud sous Facturation → Rapports.</span
                    >
                  </div>
                </div>
              </div>
            </div>

            <div class="faq-item" id="faq-d2">
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls="faq-d2-body"
              >
                <span class="faq-q-text">Ma clé API est-elle en sécurité ?</span
                >
                <span class="faq-chevron" aria-hidden="true">▾</span>
              </button>
              <div class="faq-answer" id="faq-d2-body" hidden>
                <div class="faq-answer-inner step-body">
                  <p>
                    La clé est stockée <strong
                      >exclusivement dans votre navigateur</strong
                    >, chiffrée <strong>AES-GCM 256 bits</strong>. Elle ne
                    quitte jamais votre appareil et n'est jamais transmise à nos
                    serveurs (il n'y en a pas).
                  </p>
                  <p>
                    Pour éviter qu'elle soit utilisée par quelqu'un d'autre si
                    elle était découverte, <strong
                      >restreignez-la à votre domaine</strong
                    > dans la console Google Cloud (Restrictions d'application → Référents
                    HTTP).
                  </p>
                  <p>
                    Consultez la <a href="/documentation#ch1-4">documentation</a
                    > pour la procédure complète de restriction.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- ─── CATÉGORIE E : Données et navigateur ─── -->
