{
  "name": "Universal Project Template",
  "description": "Context limitation configuration for any type of project (Python, Node.js, Rust, Go, Java, DevOps, etc.)",
  "version": "1.2.0",
  "include": [
    "*.md",
    "*.txt",
    "*.sh",
    "*.py",
    "*.js",
    "*.ts",
    "*.jsx",
    "*.tsx",
    "*.mjs",
    "*.cjs",
    "*.rs",
    "*.go",
    "*.java",
    "*.c",
    "*.cpp",
    "*.h",
    "*.hpp",
    "*.yml",
    "*.yaml",
    "*.json",
    "*.toml",
    "*.sql",
    "*.conf",
    "src/**/*",
    "app/**/*",
    "lib/**/*",
    "components/**/*",
    "pages/**/*",
    "routes/**/*",
    "routers/**/*",
    "utils/**/*",
    "helpers/**/*",
    "config/**/*",
    "migrations/**/*",
    "scripts/**/*.sh",
    "scripts/**/*.py",
    "scripts/**/*.js",
    "tests/**/*",
    "test/**/*",
    "docs/**/*",
    "Dockerfile",
    "docker-compose*.yml",
    "Caddyfile",
    "Makefile",
    "package.json",
    "package-lock.json",
    "requirements.txt",
    "Pipfile",
    "pyproject.toml",
    "poetry.lock",
    "Cargo.toml",
    "Cargo.lock",
    "go.mod",
    "go.sum",
    "tsconfig.json",
    "astro.config.mjs",
    "vite.config.ts",
    "next.config.js",
    ".env.example",
    ".gitignore",
    ".gitattributes"
  ],
  "exclude": [
    "node_modules/**/*",
    "dist/**/*",
    "build/**/*",
    ".astro/**/*",
    ".next/**/*",
    ".nuxt/**/*",
    ".cache/**/*",
    "__pycache__/**/*",
    "*.pyc",
    "*.pyo",
    ".pytest_cache/**/*",
    ".pycache",
    ".venv/**/*",
    "venv/**/*",
    "env/**/*",
    ".python-version",
    "target/**/*",
    "bin/**/*",
    "pkg/**/*",
    "out/**/*",
    "*.class",
    ".git/**/*",
    ".git/objects/**/*",
    ".git/logs/**/*",
    "logs/**/*",
    "*.log",
    ".pf/**/*",
    ".claude-code/**/*",
    "mcp-servers/**/*",
    ".env",
    ".env.local",
    ".env.*.local",
    ".env.production",
    ".env.development",
    ".env.test",
    "*.broken",
    "*.key",
    "*.pem",
    "secrets/**/*",
    "credentials/**/*",
    ".ssh/**/*",
    "*.png",
    "*.jpg",
    "*.jpeg",
    "*.gif",
    "*.svg",
    "*.webp",
    "*.avif",
    "*.pdf",
    "*.mp4",
    "*.mov",
    "*.avi",
    "public/images/**/*",
    "public/lotties/**/*",
    "public/lotties-data/**/*",
    "static/images/**/*",
    "assets/images/**/*",
    "*.db",
    "*.sqlite",
    "*.sqlite3",
    "volumes/**/*",
    "data/**/*",
    "backup/**/*",
    "*.json.br",
    ".idea/**/*",
    ".vscode/**/*",
    "*.swp",
    "*.swo",
    "*~",
    ".DS_Store",
    "npm-debug.log",
    "yarn-error.log",
    "yarn.lock",
    ".auditor_venv/**/*"
  ]
}
